## 5. QUY TẮC NESTJS MODULE

### 5.1. Cấu trúc một module hoàn chỉnh

```
src/modules/room/
├── room.module.ts           # Module declaration
├── room.service.ts          # Business logic
├── room.controller.ts       # HTTP endpoints
├── room.repository.ts       # Complex queries (optional)
├── dto/
│   ├── index.ts             # Barrel export
│   ├── create-room.dto.ts   # Input validation
│   ├── update-room.dto.ts
│   └── room-response.dto.ts # Output shape
├── interfaces/              # (optional)
│   └── room.interface.ts
└── events/                  # (optional)
    └── room-created.event.ts
```

### 5.2. Module file

```typescript
import { Module } from '@nestjs/common';
import { RoomService } from './room.service';
import { RoomController } from './room.controller';

@Module({
  controllers: [RoomController],
  providers: [RoomService],
  exports: [RoomService], // export nếu module khác cần dùng
})
export class RoomModule {}
```

### 5.3. Đăng ký module mới trong `app.module.ts`

```typescript
import { RoomModule } from '@modules/room/room.module';

@Module({
  imports: [
    // ... existing modules
    // ─── Feature Modules ───────────────────────────
    AuthModule,
    HealthModule,
    RoomModule,  // ← thêm vào đây
  ],
})
export class AppModule {}
```

### 5.4. Controller conventions

```typescript
@ApiTags('Rooms')                    // Swagger tag — tên số nhiều
@Controller('rooms')                 // Route — kebab-case, số nhiều
export class RoomController {
  constructor(private readonly roomService: RoomService) {}

  @Get()
  @ApiOperation({ summary: 'Get all rooms' })
  @ApiPagination()
  async findAll(@Query() query: PaginationDto) { }

  @Get(':id')
  @ApiOperation({ summary: 'Get room by ID' })
  async findOne(@Param('id', ParseIntPipe) id: number) { }

  @Post()
  @ApiOperation({ summary: 'Create room' })
  @UseGuards(AuthGuard('jwt'))
  @ApiBearerAuth()
  async create(@Body() dto: CreateRoomDto) { }

  @Patch(':id')                      // PATCH cho partial update, PUT cho full
  @ApiOperation({ summary: 'Update room' })
  async update(@Param('id', ParseIntPipe) id: number, @Body() dto: UpdateRoomDto) { }

  @Delete(':id')
  @ApiOperation({ summary: 'Soft delete room' })
  async remove(@Param('id', ParseIntPipe) id: number) { }
}
```

### 5.5. Service conventions

```typescript
@Injectable()
export class RoomService {
  constructor(private readonly prisma: PrismaService) {}

  // ✅ Method naming: findAll, findOne, create, update, remove
  // ✅ Luôn soft delete (set deletedAt) thay vì hard delete
  // ✅ Luôn filter deletedAt: null trong WHERE
  async findAll(query: PaginationDto): Promise<IPaginated<Room>> {
    const [data, total] = await Promise.all([
      this.prisma.room.findMany({
        where: { deletedAt: null },
        skip: query.skip,
        take: query.limit,
        orderBy: { [query.orderBy || 'createdAt']: query.order },
      }),
      this.prisma.room.count({ where: { deletedAt: null } }),
    ]);

    return {
      data,
      meta: {
        total,
        page: query.page,
        limit: query.limit,
        totalPages: Math.ceil(total / query.limit),
      },
    };
  }

  async remove(id: number): Promise<void> {
    // ✅ Soft delete
    await this.prisma.room.update({
      where: { roomId: id },
      data: { deletedAt: new Date() },
    });

    // ❌ KHÔNG hard delete
    // await this.prisma.room.delete({ where: { roomId: id } });
  }
}
```

