## 9. QUY TẮC TESTING

### 9.1. File test đặt cùng file source

```
src/modules/room/
├── room.service.ts
├── room.service.spec.ts     # Unit test
├── room.controller.ts
└── room.controller.spec.ts  # Unit test
```

### 9.2. Cấu trúc unit test

```typescript
import { Test, TestingModule } from '@nestjs/testing';
import { RoomService } from './room.service';
import { PrismaService } from '@database/prisma.service';

describe('RoomService', () => {
  let service: RoomService;
  let prisma: jest.Mocked<PrismaService>;

  beforeEach(async () => {
    const module: TestingModule = await Test.createTestingModule({
      providers: [
        RoomService,
        {
          provide: PrismaService,
          useValue: {
            room: {
              findMany: jest.fn(),
              findUnique: jest.fn(),
              create: jest.fn(),
              update: jest.fn(),
              count: jest.fn(),
            },
          },
        },
      ],
    }).compile();

    service = module.get<RoomService>(RoomService);
    prisma = module.get(PrismaService);
  });

  describe('findOne', () => {
    it('should return a room when found', async () => {
      const mockRoom = { roomId: 1, roomName: '101' };
      prisma.room.findUnique.mockResolvedValue(mockRoom as any);

      const result = await service.findOne(1);
      expect(result).toEqual(mockRoom);
    });

    it('should throw NotFoundException when room not found', async () => {
      prisma.room.findUnique.mockResolvedValue(null);

      await expect(service.findOne(999)).rejects.toThrow(NotFoundException);
    });
  });
});
```

