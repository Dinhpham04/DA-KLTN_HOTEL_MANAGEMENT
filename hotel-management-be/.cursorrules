## 6. QUY TẮC DTO & VALIDATION

### 6.1. Create DTO

```typescript
import { IsString, IsInt, IsOptional, Min, Max } from 'class-validator';
import { ApiProperty, ApiPropertyOptional } from '@nestjs/swagger';

export class CreateRoomDto {
  @ApiProperty({ description: 'Tên phòng', example: '101' })
  @IsString()
  roomName!: string;

  @ApiProperty({ description: 'Loại phòng' })
  @IsInt()
  roomClassId!: number;

  @ApiPropertyOptional({ description: 'Tầng' })
  @IsOptional()
  @IsInt()
  @Min(1)
  @Max(50)
  floor?: number;
}
```

### 6.2. Update DTO — dùng `PartialType`

```typescript
import { PartialType } from '@nestjs/swagger';
import { CreateRoomDto } from './create-room.dto';

export class UpdateRoomDto extends PartialType(CreateRoomDto) {}
```

### 6.3. Response DTO

```typescript
import { ApiProperty } from '@nestjs/swagger';

export class RoomResponseDto {
  @ApiProperty()
  roomId!: number;

  @ApiProperty()
  roomName!: string;

  @ApiProperty()
  createdAt!: Date;

  // ✅ Dùng static factory method để map từ Prisma model
  static fromEntity(room: {
    roomId: number;
    roomName: string;
    createdAt: Date;
  }): RoomResponseDto {
    const dto = new RoomResponseDto();
    dto.roomId = room.roomId;
    dto.roomName = room.roomName;
    dto.createdAt = room.createdAt;
    return dto;
  }
}
```

