# ─── App ───────────────────────────────────────────
APP_NAME=hotel-management-be
APP_PORT=3000
APP_ENV=development
APP_TIMEZONE=Asia/Tokyo

# ─── Database (PostgreSQL) ─────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel_management?schema=public"

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=super-secret-change-me-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=super-refresh-secret-change-me
JWT_REFRESH_EXPIRES_IN=7d

# ─── Throttle ─────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# ─── Cloudinary ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=hotel-management

# ─── Internal automation ──────────────────────────
# Token n8n gửi kèm khi gọi /internal/* — set cùng giá trị trong n8n credential "Hotel Internal API"
INTERNAL_AUTOMATION_TOKEN=dev-internal-token
RESERVATION_AUTOMATION_STAFF_ID=1
CLEANING_AUTOMATION_STAFF_ID=1

# ─── n8n Webhook endpoints ────────────────────────
# URL n8n nhận sự kiện từ backend — cấu hình 1 lần, dùng chung N8N_AUTOMATION_SECRET cho tất cả
N8N_RESERVATION_CREATED_WEBHOOK_URL=http://localhost:5678/webhook/reservation-created
N8N_RESERVATION_CHECKED_IN_WEBHOOK_URL=http://localhost:5678/webhook/reservation-checked-in
# Token gửi kèm mọi webhook call đến n8n — set cùng giá trị trong n8n credential "Hotel Automation Token"
N8N_AUTOMATION_SECRET=dev-automation-secret
