  checkoutReceptionist2 Staff?    @relation("ReserveCheckoutReceptionist2", fields: [checkoutReceptionistId2], references: [staffId])
  confirmStaff          Staff?    @relation("ReserveConfirmStaff", fields: [confirmStaffId], references: [staffId])
  createdBy             Staff     @relation("ReserveCreatedBy", fields: [createdStaffId], references: [staffId])
  updatedBy             Staff?    @relation("ReserveUpdatedBy", fields: [updatedStaffId], references: [staffId])
  deletedBy             Staff?    @relation("ReserveDeletedBy", fields: [deletedStaffId], references: [staffId])

  reserveOccupiers       ReserveOccupier[]
  usageStatuses          UsageStatus[]
  pinCredentials         RoomPinCredential[]
  parkingReserves        ParkingReserve[]
