// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Staff (Authentication) ─────────────────────────

model Staff {
  staffId             Int       @id @default(autoincrement()) @map("staff_id")
  dataStatus          Int       @default(1) @map("data_status") @db.SmallInt
  staffType           Int       @map("staff_type") @db.SmallInt
  staffName           String    @map("staff_name") @db.VarChar(256)
  staffNameEn         String?   @map("staff_name_en") @db.VarChar(256)
  staffNameShort      String?   @map("staff_name_short") @db.VarChar(32)
  sex                 Int       @default(9) @db.SmallInt
  zipCode             String?   @map("zip_code") @db.VarChar(9)
  address             String?   @db.VarChar(256)
  mail                String    @unique @db.VarChar(256)
  loginPassword       String    @map("login_password") @db.VarChar(256)
  tel                 String?   @db.VarChar(18)
  businessTel         String?   @map("business_tel") @db.VarChar(18)
  emergencyTel        String?   @map("emergency_tel") @db.VarChar(18)
  displayInAttendance Boolean   @default(true) @map("display_in_attendance")
  orderNum            Int?      @default(1) @map("order_num") @db.SmallInt

  // Audit fields
  createdStaffId      Int?      @map("created_staff_id")
  updatedStaffId      Int?      @map("updated_staff_id")
  deletedStaffId      Int?      @map("deleted_staff_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  // Self-relations for audit trail
  createdBy           Staff?    @relation("StaffCreatedBy", fields: [createdStaffId], references: [staffId])
  updatedBy           Staff?    @relation("StaffUpdatedBy", fields: [updatedStaffId], references: [staffId])
  deletedBy           Staff?    @relation("StaffDeletedBy", fields: [deletedStaffId], references: [staffId])
  staffsCreated       Staff[]   @relation("StaffCreatedBy")
  staffsUpdated       Staff[]   @relation("StaffUpdatedBy")
  staffsDeleted       Staff[]   @relation("StaffDeletedBy")

  // Reverse audit relations from other models
  facilitiesCreated   Facility[]  @relation("FacilityCreatedBy")
  facilitiesUpdated   Facility[]  @relation("FacilityUpdatedBy")
  facilitiesDeleted   Facility[]  @relation("FacilityDeletedBy")
  roomClassesCreated  RoomClass[] @relation("RoomClassCreatedBy")
  roomClassesUpdated  RoomClass[] @relation("RoomClassUpdatedBy")
  roomClassesDeleted  RoomClass[] @relation("RoomClassDeletedBy")
  roomTypesCreated    RoomType[]  @relation("RoomTypeCreatedBy")
  roomTypesUpdated    RoomType[]  @relation("RoomTypeUpdatedBy")
  roomTypesDeleted    RoomType[]  @relation("RoomTypeDeletedBy")
  roomsCreated        Room[]      @relation("RoomCreatedBy")
  roomsUpdated        Room[]      @relation("RoomUpdatedBy")
  roomsDeleted        Room[]      @relation("RoomDeletedBy")
  stayTypesCreated    StayType[]  @relation("StayTypeCreatedBy")
  stayTypesUpdated    StayType[]  @relation("StayTypeUpdatedBy")
  stayTypesDeleted    StayType[]  @relation("StayTypeDeletedBy")
  countriesCreated    Country[]   @relation("CountryCreatedBy")
  countriesUpdated    Country[]   @relation("CountryUpdatedBy")
  countriesDeleted    Country[]   @relation("CountryDeletedBy")

  // Phase 2: Client & Reservation
  clientsCreated          Client[]          @relation("ClientCreatedBy")
  clientsUpdated          Client[]          @relation("ClientUpdatedBy")
  clientsDeleted          Client[]          @relation("ClientDeletedBy")
  reservesCreated         Reserve[]         @relation("ReserveCreatedBy")
  reservesUpdated         Reserve[]         @relation("ReserveUpdatedBy")
  reservesDeleted         Reserve[]         @relation("ReserveDeletedBy")
  reservesCharge          Reserve[]         @relation("ReserveChargeStaff")
  reservesCharge2         Reserve[]         @relation("ReserveChargeStaff2")
  reservesCheckinRecep    Reserve[]         @relation("ReserveCheckinReceptionist")
  reservesDiContact       Reserve[]         @relation("ReserveDiContactStaff")
  reservesCheckoutRecep   Reserve[]         @relation("ReserveCheckoutReceptionist")
  reservesCheckoutRecep2  Reserve[]         @relation("ReserveCheckoutReceptionist2")
  reservesConfirmStaff    Reserve[]         @relation("ReserveConfirmStaff")
  reserveOccupiersCreated ReserveOccupier[] @relation("ReserveOccupierCreatedBy")
  reserveOccupiersUpdated ReserveOccupier[] @relation("ReserveOccupierUpdatedBy")
  reserveOccupiersDeleted ReserveOccupier[] @relation("ReserveOccupierDeletedBy")

  // Phase 3: Identification
  identificationsCreated  Identification[] @relation("IdentificationCreatedBy")
  identificationsUpdated  Identification[] @relation("IdentificationUpdatedBy")
  identificationsDeleted  Identification[] @relation("IdentificationDeletedBy")

  // Phase 4: FacilityRoomType
  facilityRoomTypesCreated  FacilityRoomType[] @relation("FacilityRoomTypeCreatedBy")
  facilityRoomTypesUpdated  FacilityRoomType[] @relation("FacilityRoomTypeUpdatedBy")
  facilityRoomTypesDeleted  FacilityRoomType[] @relation("FacilityRoomTypeDeletedBy")

  // Phase 5: Parking
  parkingsCreated           Parking[]          @relation("ParkingCreatedBy")
  parkingsUpdated           Parking[]          @relation("ParkingUpdatedBy")
  parkingsDeleted           Parking[]          @relation("ParkingDeletedBy")
  parkingRentsCreated       ParkingRent[]      @relation("ParkingRentCreatedBy")
  parkingRentsUpdated       ParkingRent[]      @relation("ParkingRentUpdatedBy")
  parkingRentsDeleted       ParkingRent[]      @relation("ParkingRentDeletedBy")

  // Phase 6: Bicycle Parking
  bicycleParkingsCreated    BicycleParking[]   @relation("BicycleParkingCreatedBy")
  bicycleParkingsUpdated    BicycleParking[]   @relation("BicycleParkingUpdatedBy")
  bicycleParkingsDeleted    BicycleParking[]   @relation("BicycleParkingDeletedBy")

  // Phase 7: Rent
  rentsCreated              Rent[]             @relation("RentCreatedBy")
  rentsUpdated              Rent[]             @relation("RentUpdatedBy")
  rentsDeleted              Rent[]             @relation("RentDeletedBy")

  // Phase 8: UsageStatus
  usageStatusesCreated      UsageStatus[]      @relation("UsageStatusCreatedBy")
  usageStatusesUpdated      UsageStatus[]      @relation("UsageStatusUpdatedBy")
  usageStatusesDeleted      UsageStatus[]      @relation("UsageStatusDeletedBy")

  // Phase 10: ParkingReserve
  parkingReservesCreated         ParkingReserve[]         @relation("ParkingReserveCreatedBy")
  parkingReservesUpdated         ParkingReserve[]         @relation("ParkingReserveUpdatedBy")
  parkingReservesDeleted         ParkingReserve[]         @relation("ParkingReserveDeletedBy")
  bicycleParkingReservesCreated  BicycleParkingReserve[]  @relation("BicycleParkingReserveCreatedBy")
  bicycleParkingReservesUpdated  BicycleParkingReserve[]  @relation("BicycleParkingReserveUpdatedBy")
  bicycleParkingReservesDeleted  BicycleParkingReserve[]  @relation("BicycleParkingReserveDeletedBy")

  // Phase 9: RoomPinCredential
  roomPinCredentialsCreated RoomPinCredential[] @relation("RoomPinCredentialCreatedBy")
  roomPinCredentialsUpdated RoomPinCredential[] @relation("RoomPinCredentialUpdatedBy")
  roomPinCredentialsDeleted RoomPinCredential[] @relation("RoomPinCredentialDeletedBy")

  // Phase 11: CleaningShift
  cleansCreated             Cleans[]            @relation("CleansCreatedBy")
  cleansUpdated             Cleans[]            @relation("CleansUpdatedBy")
  cleansDeleted             Cleans[]            @relation("CleansDeletedBy")
  cleaningDetailsCreated    CleaningDetail[]    @relation("CleaningDetailCreatedBy")
  cleaningDetailsUpdated    CleaningDetail[]    @relation("CleaningDetailUpdatedBy")
  cleaningDetailsDeleted    CleaningDetail[]    @relation("CleaningDetailDeletedBy")
  cleaningDetailsAsMain     CleaningDetail[]    @relation("CleaningDetailMainStaff")
  cleaningDetailsAsSub      CleaningDetail[]    @relation("CleaningDetailSubStaff")
  cleaningDetailsAsCheck    CleaningDetail[]    @relation("CleaningDetailCheckStaff")
  cleanDetailNotesCreated   CleanDetailNote[]   @relation("CleanDetailNoteCreatedBy")
  cleanDetailNotesUpdated   CleanDetailNote[]   @relation("CleanDetailNoteUpdatedBy")
  cleanDetailNotesDeleted   CleanDetailNote[]   @relation("CleanDetailNoteDeletedBy")

  @@index([createdStaffId], map: "staffs_created_staff_id_idx")
  @@index([updatedStaffId], map: "staffs_updated_staff_id_idx")
  @@index([deletedStaffId], map: "staffs_deleted_staff_id_idx")
  @@index([dataStatus], map: "staffs_data_status_idx")

  @@map("staffs")
}

// ─── Country (Master Data) ──────────────────────────

model Country {
  countryId       Int       @id @default(autoincrement()) @map("country_id")
  countryName     String    @map("country_name") @db.VarChar(128)
  countryNameEn   String    @map("country_name_en") @db.VarChar(128)
  code            String?   @db.VarChar(255)
  orderNum        Int       @default(196) @map("order_num") @db.SmallInt
  active          Boolean   @default(true)

  // Audit
  createdStaffId  Int       @map("created_staff_id")
  updatedStaffId  Int?      @map("updated_staff_id")
  deletedStaffId  Int?      @map("deleted_staff_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  createdBy       Staff     @relation("CountryCreatedBy", fields: [createdStaffId], references: [staffId])
  updatedBy       Staff?    @relation("CountryUpdatedBy", fields: [updatedStaffId], references: [staffId])
  deletedBy       Staff?    @relation("CountryDeletedBy", fields: [deletedStaffId], references: [staffId])

  clients         Client[]

  @@index([createdStaffId], map: "countries_created_staff_id_idx")
  @@index([updatedStaffId], map: "countries_updated_staff_id_idx")
  @@index([deletedStaffId], map: "countries_deleted_staff_id_idx")

  @@map("countries")
}

// ─── Facility (Property/Building) ───────────────────

model Facility {
  facilityId          Int       @id @default(autoincrement()) @map("facility_id")
  dataStatus          Int       @default(1) @map("data_status") @db.SmallInt
  facilityType        Int       @default(1) @map("facility_type") @db.SmallInt
  facilityNo          String    @map("facility_no") @db.VarChar(3)
  facilityName        String    @map("facility_name") @db.VarChar(256)
  facilityNameEn      String    @map("facility_name_en") @db.VarChar(256)
  zipCode             String    @map("zip_code") @db.VarChar(9)
  address             String    @db.VarChar(256)
  addressEn           String    @map("address_en") @db.VarChar(512)
  keyFunction         Boolean   @default(false) @map("key_function")
  sharePlaceFlag      Boolean   @default(false) @map("share_place_flag")
  parkingFlag         Boolean   @default(false) @map("parking_flag")
  parkingImg          String    @default("") @map("parking_img") @db.VarChar(512)
  bicycleParkingFlag  Boolean   @default(false) @map("bicycle_parking_flag")
  bicycleParkingImg   String    @default("") @map("bicycle_parking_img") @db.VarChar(512)
  deliveryboxFlag     Boolean   @default(false) @map("deliverybox_flag")
  memo                String?   @db.VarChar(1024)
  orderNum            Int       @default(1) @map("order_num") @db.SmallInt
  colorOption         String?   @map("color_option") @db.VarChar(128)

  // Audit
  createdStaffId      Int       @map("created_staff_id")
  updatedStaffId      Int?      @map("updated_staff_id")
  deletedStaffId      Int?      @map("deleted_staff_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  createdBy           Staff     @relation("FacilityCreatedBy", fields: [createdStaffId], references: [staffId])
  updatedBy           Staff?    @relation("FacilityUpdatedBy", fields: [updatedStaffId], references: [staffId])
  deletedBy           Staff?    @relation("FacilityDeletedBy", fields: [deletedStaffId], references: [staffId])

  rooms               Room[]
  reserves            Reserve[]
  facilityRoomTypes   FacilityRoomType[]
  parkings            Parking[]
  parkingRents        ParkingRent[]
  bicycleParkings     BicycleParking[]
  usageStatuses       UsageStatus[]
  cleans              Cleans[]
  cleaningDetails     CleaningDetail[]

  @@index([facilityNo], map: "facilities_facility_no_idx")
  @@index([createdStaffId], map: "facilities_created_staff_id_idx")
  @@index([updatedStaffId], map: "facilities_updated_staff_id_idx")
  @@index([deletedStaffId], map: "facilities_deleted_staff_id_idx")
  @@index([dataStatus], map: "facilities_data_status_idx")

  @@map("facilities")
}

// ─── Room Class (Standard, Deluxe...) ───────────────

model RoomClass {
  roomClassId     Int       @id @default(autoincrement()) @map("room_class_id")
  dataStatus      Int       @default(1) @map("data_status") @db.SmallInt
  roomClassName   String    @map("room_class_name") @db.VarChar(256)
  orderNum        Int       @default(1) @map("order_num") @db.SmallInt

  // Audit
  createdStaffId  Int       @map("created_staff_id")
  updatedStaffId  Int?      @map("updated_staff_id")
  deletedStaffId  Int?      @map("deleted_staff_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  createdBy       Staff     @relation("RoomClassCreatedBy", fields: [createdStaffId], references: [staffId])
  updatedBy       Staff?    @relation("RoomClassUpdatedBy", fields: [updatedStaffId], references: [staffId])
  deletedBy       Staff?    @relation("RoomClassDeletedBy", fields: [deletedStaffId], references: [staffId])

  roomTypes       RoomType[]

  @@index([createdStaffId], map: "room_classes_created_staff_id_idx")
  @@index([updatedStaffId], map: "room_classes_updated_staff_id_idx")
  @@index([deletedStaffId], map: "room_classes_deleted_staff_id_idx")
  @@index([dataStatus], map: "room_classes_data_status_idx")

  @@map("room_classes")
}

// ─── Room Type (Single, Double...) ──────────────────

model RoomType {
  roomTypeId        Int       @id @default(autoincrement()) @map("room_type_id")
  dataStatus        Int       @default(1) @map("data_status") @db.SmallInt
  roomClassId       Int       @map("room_class_id")
  roomTypeName      String    @map("room_type_name") @db.VarChar(32)
  roomTypeNameShort String    @map("room_type_name_short") @db.VarChar(32)
  acreage           Int?
  orderNum          Int       @default(1) @map("order_num") @db.SmallInt
  orderNumDeposit   Int?      @map("order_num_deposit") @db.SmallInt

  // Audit
  createdStaffId    Int       @map("created_staff_id")
  updatedStaffId    Int?      @map("updated_staff_id")
  deletedStaffId    Int?      @map("deleted_staff_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  roomClass         RoomClass @relation(fields: [roomClassId], references: [roomClassId])
  createdBy         Staff     @relation("RoomTypeCreatedBy", fields: [createdStaffId], references: [staffId])
  updatedBy         Staff?    @relation("RoomTypeUpdatedBy", fields: [updatedStaffId], references: [staffId])
  deletedBy         Staff?    @relation("RoomTypeDeletedBy", fields: [deletedStaffId], references: [staffId])

  rooms             Room[]
  facilityRoomTypes FacilityRoomType[]
  rents             Rent[]

  @@index([roomClassId], map: "room_types_room_class_id_idx")
  @@index([createdStaffId], map: "room_types_created_staff_id_idx")
  @@index([updatedStaffId], map: "room_types_updated_staff_id_idx")
  @@index([deletedStaffId], map: "room_types_deleted_staff_id_idx")
  @@index([dataStatus], map: "room_types_data_status_idx")

  @@map("room_types")
}

// ─── Room ───────────────────────────────────────────

model Room {
  roomId              Int       @id @default(autoincrement()) @map("room_id")
  facilityId          Int       @map("facility_id")
  roomTypeId          Int       @map("room_type_id")
  dataStatus          Int       @default(1) @map("data_status") @db.SmallInt
  roomNumber          String    @map("room_number") @db.VarChar(32)
  keyType             Int?      @map("key_type")
  roomStatus          Int       @map("room_status") @db.SmallInt
  reservedCleanDay    Int       @default(0) @map("reserved_clean_day") @db.SmallInt
  deliveryboxFlag     Boolean   @default(false) @map("deliverybox_flag")
  petFlag             Boolean   @default(false) @map("pet_flag")
  mailboxPassword     String    @map("mailbox_password") @db.VarChar(64)
  orderNum            Int       @default(1) @map("order_num") @db.SmallInt
  externalFlag        Boolean   @default(false) @map("external_flag")
  externalDateFrom    DateTime? @map("external_date_from") @db.Date
  externalDateTo      DateTime? @map("external_date_to") @db.Date

  // Audit
  createdStaffId      Int       @map("created_staff_id")
  updatedStaffId      Int?      @map("updated_staff_id")
  deletedStaffId      Int?      @map("deleted_staff_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  facility            Facility  @relation(fields: [facilityId], references: [facilityId])
  roomType            RoomType  @relation(fields: [roomTypeId], references: [roomTypeId])
  createdBy           Staff     @relation("RoomCreatedBy", fields: [createdStaffId], references: [staffId])
  updatedBy           Staff?    @relation("RoomUpdatedBy", fields: [updatedStaffId], references: [staffId])
  deletedBy           Staff?    @relation("RoomDeletedBy", fields: [deletedStaffId], references: [staffId])

  reserves            Reserve[]
  usageStatuses       UsageStatus[]
  pinCredentials      RoomPinCredential[]
  cleaningDetails     CleaningDetail[]

  @@index([facilityId], map: "rooms_facility_id_idx")
  @@index([roomTypeId], map: "rooms_room_type_id_idx")
  @@index([createdStaffId], map: "rooms_created_staff_id_idx")
  @@index([updatedStaffId], map: "rooms_updated_staff_id_idx")
  @@index([deletedStaffId], map: "rooms_deleted_staff_id_idx")
  @@index([dataStatus], map: "rooms_data_status_idx")
  @@index([roomStatus], map: "rooms_room_status_idx")

  @@map("rooms")
}

// ─── Stay Type (Daily/Weekly/Monthly) ───────────────

model StayType {
  stayTypeId          Int       @id @default(autoincrement()) @map("stay_type_id")
  stayContractTypeId  Int       @default(1) @map("stay_contract_type_id") @db.SmallInt
  stayTypeName        String    @map("stay_type_name") @db.VarChar(64)
  stayTypeNameEn      String    @map("stay_type_name_en") @db.VarChar(128)
  stayTypeNameShort   String    @map("stay_type_name_short") @db.VarChar(4)
  orderNum            Int       @default(99) @map("order_num") @db.SmallInt
  active              Boolean   @default(true)

  // Audit
  createdStaffId      Int       @map("created_staff_id")
  updatedStaffId      Int?      @map("updated_staff_id")
  deletedStaffId      Int?      @map("deleted_staff_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  createdBy           Staff     @relation("StayTypeCreatedBy", fields: [createdStaffId], references: [staffId])
  updatedBy           Staff?    @relation("StayTypeUpdatedBy", fields: [updatedStaffId], references: [staffId])
  deletedBy           Staff?    @relation("StayTypeDeletedBy", fields: [deletedStaffId], references: [staffId])

  reserves            Reserve[]
  parkingRents        ParkingRent[]
  rents               Rent[]

  @@index([createdStaffId], map: "stay_types_created_staff_id_idx")
  @@index([updatedStaffId], map: "stay_types_updated_staff_id_idx")
  @@index([deletedStaffId], map: "stay_types_deleted_staff_id_idx")

  @@map("stay_types")
}

// ─── Parking (Car Parking Spot) ─────────────────────

model Parking {
  parkingId           Int       @id @default(autoincrement()) @map("parking_id")
  dataStatus          Int       @default(1) @map("data_status") @db.SmallInt
  parentFacilityId    Int       @map("parent_facility_id")
  number              String    @map("number") @db.VarChar(32)
  heightLimit         Float     @map("height_limit") @db.DoublePrecision
  notice              String?   @db.VarChar(512)
  orderNum            Int       @default(99) @map("order_num") @db.SmallInt

  // Audit
  createdStaffId      Int       @map("created_staff_id")
  updatedStaffId      Int?      @map("updated_staff_id")
  deletedStaffId      Int?      @map("deleted_staff_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  parentFacility      Facility  @relation(fields: [parentFacilityId], references: [facilityId])
  createdBy           Staff     @relation("ParkingCreatedBy", fields: [createdStaffId], references: [staffId])
  updatedBy           Staff?    @relation("ParkingUpdatedBy", fields: [updatedStaffId], references: [staffId])
  deletedBy           Staff?    @relation("ParkingDeletedBy", fields: [deletedStaffId], references: [staffId])

  parkingRents        ParkingRent[]
  parkingReserves     ParkingReserve[]

  @@index([parentFacilityId], map: "parkings_parent_facility_id_idx")
  @@index([createdStaffId], map: "parkings_created_staff_id_idx")
  @@index([updatedStaffId], map: "parkings_updated_staff_id_idx")
  @@index([deletedStaffId], map: "parkings_deleted_staff_id_idx")
  @@index([dataStatus], map: "parkings_data_status_idx")

  @@map("parkings")
}

// ─── Parking Rent (Pricing per stay type) ───────────

model ParkingRent {
  parkingRentId       Int       @id @default(autoincrement()) @map("parking_rent_id")
  parkingId           Int       @map("parking_id")
  dataStatus          Int       @default(1) @map("data_status") @db.SmallInt
  facilityId          Int       @map("facility_id")
  stayTypeId          Int       @map("stay_type_id")
  unit                Int       @default(0) @db.SmallInt
  rent                Int       @default(0)

  // Audit
  createdStaffId      Int       @map("created_staff_id")
  updatedStaffId      Int?      @map("updated_staff_id")
  deletedStaffId      Int?      @map("deleted_staff_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  parking             Parking   @relation(fields: [parkingId], references: [parkingId])
  facility            Facility  @relation(fields: [facilityId], references: [facilityId])
  stayType            StayType  @relation(fields: [stayTypeId], references: [stayTypeId])
  createdBy           Staff     @relation("ParkingRentCreatedBy", fields: [createdStaffId], references: [staffId])
  updatedBy           Staff?    @relation("ParkingRentUpdatedBy", fields: [updatedStaffId], references: [staffId])
  deletedBy           Staff?    @relation("ParkingRentDeletedBy", fields: [deletedStaffId], references: [staffId])

  @@index([parkingId], map: "parking_rents_parking_id_idx")
  @@index([facilityId], map: "parking_rents_facility_id_idx")
  @@index([stayTypeId], map: "parking_rents_stay_type_id_idx")
  @@index([createdStaffId], map: "parking_rents_created_staff_id_idx")
  @@index([updatedStaffId], map: "parking_rents_updated_staff_id_idx")
  @@index([deletedStaffId], map: "parking_rents_deleted_staff_id_idx")

  @@map("parking_rents")
}

// ─── Rent (Room Pricing per Stay Type) ──────────────

model Rent {
  rentId              Int       @id @default(autoincrement()) @map("rent_id")
  dataStatus          Int       @default(1) @map("data_status") @db.SmallInt
  depositFlag         Int       @default(0) @map("deposit_flag") @db.SmallInt
  roomTypeId          Int       @map("room_type_id")
  stayTypeId          Int       @map("stay_type_id")
  depositPay          BigInt?   @map("deposit_pay")
  depositPayOver3     BigInt?   @map("deposit_pay_over3")
  dayRent             Int?      @map("day_rent")
  monthRent           BigInt?   @map("month_rent")
  dayRentOver3        Int?      @map("day_rent_over3")
  monthRentOver3      BigInt?   @map("month_rent_over3")
  dayCleanFee         Int?      @map("day_clean_fee")
  monthCleanFee       BigInt?   @map("month_clean_fee")
  dayCleanFeeOver3    Int?      @map("day_clean_fee_over3")
  monthCleanFeeOver3  BigInt?   @map("month_clean_fee_over3")
  dayMainteFee        Int?      @map("day_mainte_fee")
  monthMainteFee      BigInt?   @map("month_mainte_fee")
  dayUtilityFee       Int?      @map("day_utility_fee")
  monthUtilityFee     BigInt?   @map("month_utility_fee")

  // Audit
  createdStaffId      Int       @map("created_staff_id")
  updatedStaffId      Int?      @map("updated_staff_id")
  deletedStaffId      Int?      @map("deleted_staff_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
