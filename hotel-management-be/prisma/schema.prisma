  timeExtendNum Int? @map("time_extend_num") @db.SmallInt
  extensionTime Int? @map("extension_time") @db.SmallInt

  // Key management
  rentalKeys           Int? @map("rental_keys") @db.SmallInt
  returnKeys           Int? @map("return_keys") @db.SmallInt
  keyReturnContactType Int? @map("key_return_contact_type") @db.SmallInt

