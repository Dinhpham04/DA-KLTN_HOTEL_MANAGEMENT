  @@index([periodFrom], map: "parking_reserves_period_from_idx")
  @@index([createdStaffId], map: "parking_reserves_created_staff_id_idx")
  @@index([updatedStaffId], map: "parking_reserves_updated_staff_id_idx")
  @@index([deletedStaffId], map: "parking_reserves_deleted_staff_id_idx")
  @@index([dataStatus], map: "parking_reserves_data_status_idx")

