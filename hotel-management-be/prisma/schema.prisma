  // Pet details
  dogCount   Int?    @map("dog_count") @db.SmallInt
  catCount   Int?    @map("cat_count") @db.SmallInt
  otherCount Int?    @map("other_count") @db.SmallInt
  petNote    String? @map("pet_note") @db.VarChar(256)

  // Deliverybox
  deliveryboxCardNumber String? @map("deliverybox_card_number") @db.VarChar(16)

  // Notes & announcements
  note                String? @db.VarChar(256)
  memo                String? @db.Text
  overdueDebtNote     String? @map("overdue_debt_note") @db.Text
  amendment           String? @db.VarChar(128)
  cancelReason        String? @map("cancel_reason") @db.VarChar(512)
  announcement        String? @db.VarChar(1024)
  requestAnnouncement String? @map("request_announcement") @db.VarChar(1024)
  saleAnnouncement    String? @map("sale_announcement") @db.VarChar(1024)
