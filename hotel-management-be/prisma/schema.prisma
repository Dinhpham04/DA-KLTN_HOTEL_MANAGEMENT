  chargeStaffId           Int? @map("charge_staff_id")
  chargeStaffId2          Int? @map("charge_staff_id2")
  checkinReceptionistId   Int? @map("checkin_receptionist_id")
  diContactStaffId        Int? @map("di_contact_staff_id")
  checkoutReceptionistId  Int? @map("checkout_receptionist_id")
  checkoutReceptionistId2 Int? @map("checkout_receptionist_id_2")
  confirmStaffId          Int? @map("confirm_staff_id")

