  @@index([clientId], map: "reserves_client_id_idx")
  @@index([facilityId], map: "reserves_facility_id_idx")
  @@index([roomId], map: "reserves_room_id_idx")
  @@index([stayTypeId], map: "reserves_stay_type_id_idx")
  @@index([reserveStatus], map: "reserves_reserve_status_idx")
  @@index([periodFrom], map: "reserves_period_from_idx")
  @@index([periodTo], map: "reserves_period_to_idx")
  @@index([chargeStaffId], map: "reserves_charge_staff_id_idx")
  @@index([chargeStaffId2], map: "reserves_charge_staff_id2_idx")
  @@index([checkinReceptionistId], map: "reserves_checkin_receptionist_id_idx")
  @@index([diContactStaffId], map: "reserves_di_contact_staff_id_idx")
  @@index([checkoutReceptionistId], map: "reserves_checkout_receptionist_id_idx")
  @@index([checkoutReceptionistId2], map: "reserves_checkout_receptionist_id_2_idx")
  @@index([confirmStaffId], map: "reserves_confirm_staff_id_idx")
  @@index([createdStaffId], map: "reserves_created_staff_id_idx")
  @@index([updatedStaffId], map: "reserves_updated_staff_id_idx")
  @@index([deletedStaffId], map: "reserves_deleted_staff_id_idx")
  @@index([dataStatus], map: "reserves_data_status_idx")
  @@map("reserves")
}

