  checkinReceptionist   Staff?    @relation("ReserveCheckinReceptionist", fields: [checkinReceptionistId], references: [staffId])
  diContactStaff        Staff?    @relation("ReserveDiContactStaff", fields: [diContactStaffId], references: [staffId])
