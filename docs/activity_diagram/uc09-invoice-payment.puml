@startuml uc09_invoice_debt_management
start

:Nhân viên mở đặt phòng;
:Chọn chức năng tạo/cập nhật hóa đơn;
:Hệ thống tải dữ liệu đặt phòng và khoản phát sinh;
:Tạo danh sách hạng mục hóa đơn dự kiến;
:Nhân viên kiểm tra, bổ sung hoặc điều chỉnh hạng mục;
:Hệ thống tính tổng phải thu, số đã ghi nhận, số còn nợ;

if (Dữ liệu hóa đơn hợp lệ?) then (Có)
  :Lưu hóa đơn nháp hoặc chốt hóa đơn;
  if (Có số tiền đã thu cần cập nhật?) then (Có)
    :Nhập số tiền, ngày ghi nhận, ghi chú/chứng từ;
    if (Số tiền hợp lệ?) then (Có)
      :Cập nhật số đã ghi nhận và công nợ còn lại;
    else (Không)
      :Cảnh báo số tiền không hợp lệ;
    endif
  endif

  if (Còn công nợ?) then (Có)
    :Giữ hóa đơn trong danh sách công nợ;
    :Phát sự kiện nhắc công nợ nếu cần;
  else (Không)
    :Đóng trạng thái công nợ;
  endif

  :Xuất hóa đơn hoặc phiếu xác nhận công nợ;
else (Không)
  :Thông báo thiếu/sai dữ liệu hóa đơn;
endif

stop
@enduml
