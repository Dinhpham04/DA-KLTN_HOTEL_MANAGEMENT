@startuml uc05_update_extend_cancel_reservation
start

:Người dùng mở chi tiết đặt phòng;
:Chọn thao tác cần thực hiện;

if (Điều chỉnh thông tin?) then (Có)
  :Cập nhật thời gian, phòng, khách ở cùng hoặc ghi chú;
  :Hệ thống kiểm tra quyền và trạng thái đặt phòng;
  if (Thay đổi ảnh hưởng lịch phòng?) then (Có)
    :Kiểm tra xung đột lịch;
  endif
  if (Hợp lệ?) then (Có)
    :Lưu thay đổi;
    :Ghi lịch sử thao tác;
  else (Không)
    :Hiển thị lỗi và yêu cầu chọn phương án khác;
  endif
elseif (Gia hạn?) then (Có)
  :Nhập ngày/giờ trả phòng mới;
  :Kiểm tra phòng còn trống trong khoảng gia hạn;
  :Tính khoản phát sinh nếu có;
  if (Có thể gia hạn?) then (Có)
    :Cập nhật thời gian lưu trú và lịch phòng;
  else (Không)
    :Thông báo phòng không còn trống;
  endif
else (Hủy)
  :Hiển thị trạng thái đặt phòng, đặt cọc/công nợ;
  :Nhập lý do hủy;
  if (Cho phép hủy?) then (Có)
    :Cập nhật trạng thái đã hủy;
    :Giải phóng lịch phòng;
    :Ghi lịch sử hủy;
  else (Không)
    :Từ chối hủy và hiển thị lý do;
  endif
endif

stop
@enduml
