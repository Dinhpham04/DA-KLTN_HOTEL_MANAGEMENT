      ]
    },
    {
      "parameters": {
        "jsCode": "const result = $json.data ?? $json\nreturn [{ json: { dailyReserve: result, checkins: result.checkins ?? result.checkIns ?? [], checkouts: result.checkouts ?? result.checkOuts ?? [], sources: [{ type: 'api', name: 'GET /daily-reserve' }] } }]"
      },
      "id": "2c19d1a7-6f7e-4bb8-9f01-000000000304",
